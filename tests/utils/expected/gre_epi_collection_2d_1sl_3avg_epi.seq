# Field 'use' is the initial of: 
#   excitation refocusing inversion saturation preparation other undefined
[RF]
1      130.746 1 2 0 4000 0 -3.35 0.0841947 0 0 s
2      502.446 3 4 0 1000 60 0 0 0 0 e
3      502.446 3 4 0 1000 60 0 0 0 -0 e

# Format of arbitrary gradients:
#   time_shape_id of 0 means default timing (stepping with grad_raster starting at 1/2 of grad_raster)
# id amplitude first last amp_shape_id time_shape_id delay
# ..      Hz/m  Hz/m Hz/m        ..         ..          us
[GRADIENTS]
8     -75757.6            0     -75757.6 5 6 620
9     -75757.6     -75757.6     -75757.6 7 8 0
10     -75757.6     -75757.6            0 9 6 0

# Format of trapezoid gradients:
# id amplitude rise flat fall delay
# ..      Hz/m   us   us   us    us
[TRAP]
