# Minimal Pulseq file for segment parsing tests

[VERSION]
major 1
minor 5
revision 0

[DEFINITIONS]
AdcRasterTime 1e-07
BlockDurationRaster 1e-05
GradientRasterTime 1e-05
RadiofrequencyRasterTime 1e-06

# Format of blocks:
# NUM DUR RF  GX  GY  GZ  ADC  EXT
[BLOCKS]
1 10 0 0 0 0 0 1
2 10 0 0 0 0 0 0
3 10 0 0 0 0 0 3
4 10 0 0 0 0 0 4
5 10 0 0 0 0 0 5
6 10 0 0 0 0 0 6
7 10 0 0 0 0 0 7

# Format of extension lists:
# id type ref next_id
# next_id of 0 terminates the list
# Extension list is followed by extension specifications
[EXTENSIONS]
1 1 1 2
2 1 3 0
3 1 4 0
4 1 5 0
5 1 4 0
6 1 5 0
7 1 2 8
8 1 4 0

# Extension specification for setting labels:
# id set labelstring
extension LABELSET 1
1 1 TRID
2 2 TRID
3 1 COREID
4 4 COREID
5 2 COREID
